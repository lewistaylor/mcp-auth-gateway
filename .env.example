# MCP Auth Gateway — Self-hosted OAuth 2.1 for MCP servers
#
# Embeds @mcpauth/auth as the authorization server with a simple
# username/password login. No external auth provider needed.
#
# Quick start:
#   1. Copy this to .env and fill in the values
#   2. Generate a private key:  openssl genpkey -algorithm RSA -out key.pem -pkeyopt rsa_keygen_bits:2048
#   3. Generate a secret:       openssl rand -hex 32
#   4. npm install && npm start

# ── Gateway credentials ──────────────────────────────────────────────────────
# Username and password for the login page (OAuth consent flow).
GATEWAY_USERNAME=admin
GATEWAY_PASSWORD=changeme

# ── Public URL ───────────────────────────────────────────────────────────────
# The gateway's public URL (no trailing slash). Used as the OAuth issuer URL.
BASE_URL=http://localhost:8000

# ── @mcpauth/auth ────────────────────────────────────────────────────────────
# Allowed CORS origins for the OAuth flow (comma-separated, or * for any)
MCPAUTH_ALLOWED_ORIGIN=*

# Secret for signing the OAuth state parameter
MCPAUTH_SECRET=<run: openssl rand -hex 32>

# RSA private key for signing JWTs (PEM format, newlines as \n)
# Generate: openssl genpkey -algorithm RSA -out key.pem -pkeyopt rsa_keygen_bits:2048
# Then paste the contents here with literal \n for newlines
MCPAUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Storage ──────────────────────────────────────────────────────────────────
# SQLite database path (clients, tokens, auth codes)
# On Railway, attach a volume and set this to /data/db.sqlite
# DATABASE_PATH=./data/db.sqlite

# ── Networking ───────────────────────────────────────────────────────────────
# Internal service discovery suffix (default works on Railway)
# INTERNAL_SUFFIX=-mcp.railway.internal

# Port that backend MCP services listen on
# INTERNAL_PORT=8000

# ── Public service paths (bypass Bearer auth) ───────────────────────────────
# Comma-separated list of `<service>:<path>` pairs that should be proxied
# WITHOUT requiring an MCP OAuth 2.1 Bearer token. Path matching is exact
# (no prefixes, no wildcards) and query strings are ignored.
#
# Use only for endpoints that are safe to expose publicly — typically
# OAuth callback endpoints on upstream services which are already secured
# by state/PKCE at the application layer.
#
# Example (enables Gmail's server-side OAuth consent flow):
# PUBLIC_SERVICE_PATHS=gmail:/oauth2callback,gmail:/auth/start
