# MCP Auth Gateway
#
# OAuth 2.1 auth gateway for MCP servers. Validates JWT tokens from Auth0
# and proxies authenticated requests to internal MCP backend services.
#
# Setup:
#   1. Create an Auth0 account and tenant (https://auth0.com/signup)
#   2. Enable "Resource Parameter Compatibility Profile" in Auth0 Dashboard
#      → Settings → Advanced
#   3. Enable Dynamic Client Registration in Auth0 Dashboard
#      → Settings → Advanced → enable_dynamic_client_registration
#   4. Promote your database connection to domain-level:
#      auth0 api patch connections/YOUR_CONNECTION_ID \
#        --data '{"is_domain_connection": true}'
#   5. Create an API in Auth0 (Settings → APIs → Create API):
#      - Identifier: same as AUTH0_AUDIENCE below
#      - Signing Algorithm: RS256
#   6. Set the env vars below on your Railway service

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Your Auth0 tenant domain (e.g. myapp.us.auth0.com)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# The API identifier you created in Auth0 — must match the Railway public URL
# with trailing slash (e.g. https://mcp-auth-gateway-production-XXXX.up.railway.app/)
AUTH0_AUDIENCE=https://your-gateway-url.up.railway.app/

# ── Networking ───────────────────────────────────────────────────────────────
# Internal service discovery suffix (default works on Railway)
# INTERNAL_SUFFIX=-mcp.railway.internal

# Port that backend MCP services listen on
# INTERNAL_PORT=8000
